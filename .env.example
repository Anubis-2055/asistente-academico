# .env.example
# Copia este archivo a .env antes de correr `make up` (.env queda excluido
# del repositorio por .gitignore). Los valores por defecto son seguros
# para desarrollo local; NUNCA usar estas credenciales en producción.

# --- PostgreSQL ---
POSTGRES_DB=asistente_academico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_only_change_me
